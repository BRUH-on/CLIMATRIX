NODE_ENV=development
PORT=4000

# PostgreSQL connection (adjust for your local / docker-compose DB)
DATABASE_URL=postgresql://climacore:climacore@localhost:5432/climacore?schema=public

# Comma-separated list of allowed origins, or "*" for any
CORS_ORIGIN=http://localhost:5173

# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Phase 3 (auth) — REQUIRED before hitting any /auth/* endpoint.
# Generate strong secrets, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Each secret must be at least 32 characters.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Optional — read by `npm run prisma:seed` to bootstrap the first ADMIN user.
# Leave blank to skip. ADMIN_PASSWORD must be at least 10 characters.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=
